# ----------------------------------------------------------------------------
# agentkit — example environment variables
# ----------------------------------------------------------------------------
# Copy to `.env` (or export in your shell) and fill in real values.
# `.env` is git- and docker-ignored; `.env.example` is the canonical list.
#
# Inventory rules:
#   * SDK vars are everything read under `src/agentkit/` via a
#     centralized Settings manager context tracking block.
#   * Example-only vars are read by scripts under `examples/`.
# ----------------------------------------------------------------------------

# ===== SDK — required ========================================================

# Postgres DSN for intercept storage, trusted-endpoint registry, and the
# handoff preprocess/padding path. Hosted PostgreSQL only — see
# `examples/local_model/README.md` for details.
# Read by: get_settings() -> agentkit.Settings.postgres_url
AGENTKIT_POSTGRES_URL=postgresql://user:password@db-host.example.com:5432/provably

# Provably integration API key (created under "User settings -> API Key -> Active key"
# at https://app.provably.ai). Used for handoff/evaluator HTTP calls as `x-api-key`.
# Read by: get_settings() -> agentkit.Settings.api_key
AGENTKIT_API_KEY=zk-XXX

# Provably organisation UUID. Scopes trusted-endpoint, intercept, and
# query-record lookups. Must be a valid UUID string format.
# Read by: get_settings() -> agentkit.Settings.org_id
AGENTKIT_ORG_ID=00000000-0000-0000-0000-000000000000

# ===== SDK — optional (Defaults provided by Settings manager) =================

# Base URL of the Provably backend REST engine API (Default: https://api.provably.ai).
# Read by: get_settings() -> agentkit.Settings.provably_api
# AGENTKIT_PROVABLY_API_URL=https://api.provably.ai

# Override for UI deep-links in human-readable query-record URLs (Default: https://app.provably.ai).
# Read by: get_settings() -> agentkit.Settings.provably_app
# AGENTKIT_PROVABLY_APP_URL=https://app.provably.ai

# Provably MCP Server URL target endpoint (Default: https://mcp.provably.ai).
# Read by: get_settings() -> agentkit.Settings.provably_mcp
# AGENTKIT_PROVABLY_MCP_URL=https://mcp.provably.ai

# ===== Examples-only =========================================================
# The variables below are NOT read by the SDK Settings class. They are used 
# only by scripts under `examples/`. Set them when running those examples;
# leave them unset otherwise.

# OpenRouter API key for the model call in `examples/openai_agents/agent_run.py`.
# OPENROUTER_API_KEY=sk-or-XXX

# Docker Model Runner endpoint for `examples/local_model/agent_run.py`
# (default: http://localhost:12434/engines/v1/chat/completions).
# LOCAL_MODEL_URL=http://localhost:12434/engines/v1/chat/completions

# Model id for `examples/local_model/agent_run.py`, as pulled via
# `docker model pull` (default: huggingface.co/qwen/qwen3.5-0.8b-base).
# LOCAL_MODEL=huggingface.co/qwen/qwen3.5-0.8b-base