# ----------------------------------------------------------------------------
# provably-sdk — example environment variables
# ----------------------------------------------------------------------------
# Copy to `.env` (or export in your shell) and fill in real values.
# `.env` is git- and docker-ignored; `.env.example` is the canonical list.
#
# Inventory rules:
#   * SDK vars are everything read under `src/provably/` (see grep:
#     `os.getenv` / `os.environ` / `get_env_str` in that tree).
#   * Example-only vars are read by scripts under `examples/`.
#   * Anything mentioned only in docs but never read is *not* listed here;
#     update the docs instead so this file stays the single source of truth.
# ----------------------------------------------------------------------------

# ===== SDK — required ========================================================

# Postgres DSN for intercept storage, trusted-endpoint registry, and the
# handoff preprocess/padding path. Hosted PostgreSQL only — see
# `examples/local_model/README.md` for details.
# Read by: src/provably/intercept/_storage.py,
#          src/provably/trusted_endpoints,
#          src/provably/handoff/{client,_bootstrap,payload_builder}.py
POSTGRES_URL=postgresql://user:password@db-host.example.com:5432/provably

# Provably integration API key (created under "User settings -> Integrations"
# at https://app.provably.ai). Used for handoff/evaluator HTTP calls as
# `x-api-key` and warmed into the runtime cache by `initialize_runtime`.
# Read by: src/provably/handoff/_http.py
PROVABLY_API_KEY=zk-XXX

# Provably organisation UUID. Scopes trusted-endpoint, intercept, and
# query-record lookups.
# Read by: src/provably/handoff/_http.py,
#          src/provably/intercept/_storage.py,
#          src/provably/handoff/payload_builder.py
PROVABLY_ORG_ID=XXX

# Base URL of the Provably backend (cloud default: https://api.provably.ai).
# Used by `initialize_runtime`, the evaluator, and the handoff transport.
# Read by: src/provably/handoff/_http.py
PROVABLY_RUST_BE_URL=https://api.provably.ai

# Provably MCP URL. Embedded into outgoing `HandoffPayload`s and used as the
# default `handoff_evaluate_url` when indexing is on.
# Read by: src/provably/handoff/payload_builder.py
PROVABLY_MCP_URL=https://mcp.provably.ai

# ===== SDK — optional ========================================================

# Override for UI deep-links in human-readable query-record URLs. When unset,
# the SDK infers the admin app host from `PROVABLY_RUST_BE_URL` on the
# `*.provably.ai` cloud, and otherwise falls back to the JSON API URL.
# Read by: src/provably/handoff/_http.py
# PROVABLY_APP_UI_URL=https://app.provably.ai

# ===== Examples-only =========================================================
# The variables below are NOT read by the SDK. They are used only by scripts
# under `examples/`. Set them when running those examples; leave them unset
# otherwise.

# OpenRouter API key for the model call in `examples/openai_agents/agent_run.py`.
# OPENROUTER_API_KEY=sk-or-XXX

# Docker Model Runner endpoint for `examples/local_model/agent_run.py`
# (default: http://localhost:12434/engines/v1/chat/completions).
# LOCAL_MODEL_URL=http://localhost:12434/engines/v1/chat/completions

# Model id for `examples/local_model/agent_run.py`, as pulled via
# `docker model pull` (default: huggingface.co/qwen/qwen3.5-0.8b-base).
# LOCAL_MODEL=huggingface.co/qwen/qwen3.5-0.8b-base
